{
  "productName": "BTPC Desktop",
  "version": "1.0.0",
  "identifier": "com.btpc.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "BTPC Blockchain Manager",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/btpc-icon-32.png",
      "icons/btpc-icon-64.png",
      "icons/btpc-icon-128.png",
      "icons/btpc-icon-256.png",
      "icons/btpc-icon-512.png"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {},
      "rpm": {}
    }
  }
}